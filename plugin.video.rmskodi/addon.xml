<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.rmskodi" version="1.0.0" name="RuMotoSport Kodi" provider-name="arciom">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">MotoGP 2026 race recordings from RuMotoSport</summary>
    <description lang="en_GB">Browse and play MotoGP 2026 race recordings from cloud.strea.ru. Features HLS streaming, multiple championships (MotoGP/Moto2/Moto3), and archive access.</description>
    <license>GPL-2.0-or-later</license>
    <platform>all</platform>
  </extension>
</addon>
